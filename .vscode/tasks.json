{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build all c files",
      "type": "shell",
      "command": "gcc",
      "args": [
        "main.c",
        "user.c",
        "file.c",
        "-g",
        "-o",
        "main.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}/Project6"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}